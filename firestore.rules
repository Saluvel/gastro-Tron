rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isValidUserProgress(data) {
      return data.keys().hasAll(['uid', 'totalAttempted', 'totalCorrect', 'streak', 'byTopic', 'reviewIds', 'achievements', 'updatedAt'])
        && data.uid is string && data.uid == request.auth.uid
        && data.totalAttempted is number 
        && data.totalCorrect is number
        && data.streak is number
        && data.byTopic is map 
        && data.reviewIds is list && data.reviewIds.size() <= 1000
        && data.achievements is list && data.achievements.size() <= 100
        && data.updatedAt == request.time;
    }
    
    function isValidUserProgressUpdate(data) {
      return data.uid is string && data.uid == request.auth.uid
        && data.totalAttempted is number 
        && data.totalCorrect is number
        && data.streak is number
        && data.byTopic is map 
        && data.reviewIds is list && data.reviewIds.size() <= 1000
        && data.achievements is list && data.achievements.size() <= 100
        && data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUserProgress(incoming());
      
      allow update: if isOwner(userId) 
        && isValidId(userId)
        && isValidUserProgressUpdate(incoming())
        && incoming().uid == existing().uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['totalAttempted', 'totalCorrect', 'streak', 'byTopic', 'reviewIds', 'achievements', 'activeQuiz', 'updatedAt']);
      
      allow delete: if false;

      match /pearls/{pearlId} {
        function isValidPearl(data) {
          return data.keys().hasAll(['qId', 'text', 'explanation', 'fisiopato', 'topic', 'createdAt'])
            && data.keys().size() == 6
            && data.qId is string && data.qId.size() <= 128
            && data.text is string && data.text.size() <= 10000
            && data.explanation is string && data.explanation.size() <= 10000
            && data.fisiopato is string && data.fisiopato.size() <= 10000
            && data.topic is string && data.topic.size() <= 128
            && data.createdAt == request.time;
        }

        allow get: if isOwner(userId);
        allow list: if isOwner(userId); 
        
        allow create: if isOwner(userId)
          && isValidId(userId)
          && isValidId(pearlId)
          && isValidPearl(incoming())
          && exists(/databases/$(database)/documents/users/$(userId));
        
        allow update: if false;
        
        allow delete: if isOwner(userId);
      }
    }
  }
}
